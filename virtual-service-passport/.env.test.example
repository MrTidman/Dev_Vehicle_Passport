# Environment variables for testing
# Copy this file to .env.test and fill in your values

# Base URL for testing (local dev or deployed)
BASE_URL=http://localhost:5173

# Pre-configured test credentials (optional)
# TEST_EMAIL=test@example.com
# TEST_PASSWORD=your_password_here

# Supabase credentials (optional - for test cleanup)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key